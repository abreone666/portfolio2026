{
  "outputDirectory": ".",
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "antonioilacqua.it" }], "destination": "https://www.antonioilacqua.it/$1", "permanent": true },
    { "source": "/servizi/siti-vetrina.html", "destination": "/servizi/realizzazione-siti-web-milazzo/", "permanent": true },
    { "source": "/servizi/e-commerce.html", "destination": "/servizi/ecommerce-woocommerce-milazzo/", "permanent": true },
    { "source": "/servizi/local-seo.html", "destination": "/servizi/consulenza-local-seo-milazzo/", "permanent": true },
    { "source": "/servizi/rebranding.html", "destination": "/servizi/rebranding-identita-visiva-milazzo/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/contact.php", "destination": "/api/contact" },
    { "source": "/servizi/realizzazione-siti-web-milazzo/", "destination": "/servizi/siti-vetrina.html" },
    { "source": "/servizi/ecommerce-woocommerce-milazzo/", "destination": "/servizi/e-commerce.html" },
    { "source": "/servizi/consulenza-local-seo-milazzo/", "destination": "/servizi/local-seo.html" },
    { "source": "/servizi/rebranding-identita-visiva-milazzo/", "destination": "/servizi/rebranding.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/asset/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/asset/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/asset/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/asset/3d/(.*)\\.glb",
      "headers": [
        { "key": "Content-Type", "value": "model/gltf-binary" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
